# ------------------------------
# Project environment
# ------------------------------
PTIQ_ENV=development
PTIQ_LOG_LEVEL=INFO

# ------------------------------
# Groq / Agent 0
# We keep actual keys in keys.json by default.
# This env file tells the app where to find them and which models to prefer.
# ------------------------------
GROQ_KEYS_PATH=keys.json
GROQ_EXTRACTION_MODEL=llama-3.1-8b-instant
GROQ_REASONING_MODEL=llama-3.3-70b-versatile
GROQ_REQUEST_TIMEOUT_SECONDS=60
GROQ_TOKEN_SAFETY_MARGIN=500
GROQ_MIN_OUTPUT_TOKENS=300

# ------------------------------
# Qdrant
# ------------------------------
QDRANT_URL=https://your-cluster-url
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_TENDER_COLLECTION=tender_library
QDRANT_BUSINESS_COLLECTION=business_dna

# ------------------------------
# Embeddings
# ------------------------------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ------------------------------
# Matching / calibration
# ------------------------------
MATCH_SCORE_THRESHOLD=0.72
MATCH_SCORE_FLOOR_FOR_DEMOS=0.70
CAPACITY_RISK_MULTIPLIER=10

# ------------------------------
# Scraper settings
# ------------------------------
PPIP_BASE_URL=https://tenders.go.ke
PPIP_CONTRACTS_URL=https://tenders.go.ke/Contracts
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; TenderIQ-Scraper/1.0)
SCRAPER_DELAY_SECONDS=2
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=2

# ------------------------------
# Local data paths
# These are relative to the project root unless we decide otherwise later.
# ------------------------------
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_LOG_DIR=data/logs
DEMOS_DIR=demos

# ------------------------------
# Output generation
# ------------------------------
BRIEF_OUTPUT_DIR=output
